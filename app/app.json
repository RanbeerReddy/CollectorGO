      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.collectorgo.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ab95b348-6ad6-4286-acaa-a0f4a879d6a2"
      }
    }
  }
